{
  "name": "@seasb/type-id",
  "version": "0.1.0",
  "description": "TypeScript-first toolkit for type-prefixed human-readable IDs that map to your system entity types (e.g. t_a3f9bc)",
  "keywords": [
    "id",
    "entity",
    "prefix",
    "typescript",
    "typed"
  ],
  "license": "MIT",
  "author": "Sebastian Kade",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
